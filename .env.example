RAG_PLATFORM_APP_NAME="Rag Platform"
RAG_PLATFORM_SERVICE_NAME="rag-platform-api"
RAG_PLATFORM_ENVIRONMENT="local"
RAG_PLATFORM_DEBUG=true
RAG_PLATFORM_API_VERSION="v1"
RAG_PLATFORM_LOG_LEVEL="INFO"
RAG_PLATFORM_LOG_FORMAT="text"
RAG_PLATFORM_METRICS_ENABLED=true
RAG_PLATFORM_DATABASE_URL="sqlite:///./rag_platform.db"
RAG_PLATFORM_UPLOAD_DIR="storage/uploads"
RAG_PLATFORM_ARTIFACT_DIR="storage/artifacts"
RAG_PLATFORM_MAX_UPLOAD_SIZE_BYTES=10485760
RAG_PLATFORM_CHUNK_MAX_TOKENS=300
RAG_PLATFORM_CHUNK_OVERLAP_TOKENS=40
RAG_PLATFORM_OCR_ENABLED=true
RAG_PLATFORM_OCR_LOW_CONFIDENCE_THRESHOLD=0.65
RAG_PLATFORM_MEDIA_ASYNC_ENABLED=true
RAG_PLATFORM_MEDIA_MAX_SYNC_SIZE_BYTES=10485760
RAG_PLATFORM_WHISPER_MODEL_NAME="base"
RAG_PLATFORM_CORS_ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
RAG_PLATFORM_JWT_SECRET_KEY="dev-change-me"
RAG_PLATFORM_JWT_ALGORITHM="HS256"
RAG_PLATFORM_ACCESS_TOKEN_EXPIRE_MINUTES=1440
